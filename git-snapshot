#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: git snapshot [options]               Take a snapshot
       git snapshot list                    List snapshots
       git snapshot show [N] [diff-opts]    Diff snapshot N against HEAD (default: 0)
       git snapshot files [N]               List files in snapshot N
       git snapshot restore N [path...]     Restore files from snapshot N into worktree
       git snapshot drop N                  Remove snapshot N

Snapshots capture the full working tree (tracked + untracked) as a commit
object, without touching the index or working tree. They're stored in the
reflog for refs/snapshots and expire naturally with gc.

To view a file from a snapshot: git show refs/snapshots@{N}:path/to/file

Options:
  -m, --message <msg>   Snapshot message (default: "snapshot")
  -i, --ignored         Include ignored files
  -h, --help            Show this help
USAGE
}

die() {
  echo "error: $1" >&2
  exit 1
}

# Resolve snapshot ref from N (e.g. 0 -> refs/snapshots@{0})
resolve_snap() {
  local n="${1:-0}"
  local ref="refs/snapshots@{$n}"
  git rev-parse --verify "$ref" >/dev/null 2>&1 || die "snapshot @{$n} not found"
  echo "$ref"
}

cmd_snapshot() {
  local message="" include_ignored=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -m|--message) message="${2:-}"; [[ -n "$message" ]] || die "--message requires a value"; shift 2 ;;
      --message=*) message="${1#--message=}"; [[ -n "$message" ]] || die "--message requires a value"; shift ;;
      -i|--ignored) include_ignored=true; shift ;;
      -h|--help) usage; exit 0 ;;
      --) shift; break ;;
      *) die "unknown option: $1" ;;
    esac
  done

  [[ -z "$message" ]] && message="snapshot"

  cd "$(git rev-parse --show-toplevel)"
  local git_dir
  git_dir=$(git rev-parse --git-dir)

  # Guard: need at least one commit
  git rev-parse --verify HEAD >/dev/null 2>&1 || die "no commits yet; make an initial commit first"

  # Guard: index must exist
  [[ -f "$git_dir/index" ]] || die "no index found; make an initial commit first"

  # NB: tmp must NOT be local — the EXIT trap fires after the function scope
  # ends (on set -e failure), so a local would be unbound and leak the file.
  _snapshot_tmp=$(mktemp)
  trap 'rm -f "$_snapshot_tmp" 2>/dev/null' EXIT

  cp "$git_dir/index" "$_snapshot_tmp" || die "failed to copy index"

  if [[ "$include_ignored" == true ]]; then
    GIT_INDEX_FILE="$_snapshot_tmp" git add -A --force 2>/dev/null
  else
    GIT_INDEX_FILE="$_snapshot_tmp" git add -A 2>/dev/null
  fi

  local tree commit
  tree=$(GIT_INDEX_FILE="$_snapshot_tmp" git write-tree)
  rm -f "$_snapshot_tmp"
  trap - EXIT

  commit=$(git commit-tree "$tree" -p HEAD -m "$message")
  git update-ref --create-reflog -m "$message" refs/snapshots "$commit"
  echo "$commit"
}

cmd_list() {
  local output
  output=$(git reflog show refs/snapshots --format='%C(auto)%h %C(green)%gd%C(reset) %gs  %C(dim)%ci%C(reset)' 2>/dev/null) || true
  if [[ -z "$output" ]]; then
    echo "no snapshots"
  else
    echo "$output"
  fi
}

cmd_show() {
  local ref n=0
  # First arg is the snapshot index only if it looks like a non-negative integer
  if [[ "${1:-}" =~ ^[0-9]+$ ]]; then
    n="$1"; shift
  fi
  ref=$(resolve_snap "$n")
  # Default to --stat unless the caller passes their own format flag
  if [[ $# -eq 0 ]]; then
    git diff --stat HEAD "$ref"
  else
    git diff HEAD "$ref" "$@"
  fi
}

cmd_files() {
  local ref
  ref=$(resolve_snap "${1:-0}")
  git ls-tree -r --name-only "$ref"
}

cmd_drop() {
  [[ $# -ge 1 ]] || die "usage: git snapshot drop N"
  local ref
  ref=$(resolve_snap "$1")
  git reflog delete "$ref"
}

cmd_restore() {
  [[ $# -ge 1 ]] || die "usage: git snapshot restore N [path...]"
  local ref n="$1"
  ref=$(resolve_snap "$n")
  shift

  if [[ $# -eq 0 ]]; then
    # Restore the full tree from the repo root, regardless of cwd
    cd "$(git rev-parse --show-toplevel)"
    git restore --source="$ref" --worktree -- .
  else
    git restore --source="$ref" --worktree -- "$@"
  fi
}

# --- main ---

# Help works anywhere, even outside a git repo
[[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && { usage; exit 0; }

# Guard: must be inside a git working tree
[[ "$(git rev-parse --is-inside-work-tree 2>/dev/null)" == "true" ]] || die "not a git repository (or not inside a work tree)"

case "${1:-}" in
  ""|-m|--message|--message=*|-i|--ignored|--)
    cmd_snapshot "$@" ;;
  list|show|files|restore|drop)
    cmd="$1"; shift
    [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && { usage; exit 0; }
    "cmd_$cmd" "$@" ;;
  *)
    die "unknown command: $1 (see git snapshot --help)" ;;
esac
